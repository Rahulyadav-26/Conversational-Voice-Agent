# ─── LiveKit ───────────────────────────────────────────────
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# ─── LLM / STT / TTS ───────────────────────────────────────
GROQ_API_KEY=your_groq_api_key
DEEPGRAM_API_KEY=your_deepgram_api_key
CARTESIA_API_KEY=your_cartesia_api_key

# ─── Twilio (SIP Warm Transfer) ────────────────────────────
# Your Twilio Account SID and Auth Token
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Twilio Elastic SIP Trunk domain (e.g. my-trunk.pstn.twilio.com)
SIP_TRUNK_HOSTNAME=your-trunk.pstn.twilio.com

# Twilio SIP credentials (from the Credential List in Twilio Console)
SIP_AUTH_USERNAME=your_sip_username
SIP_AUTH_PASSWORD=your_sip_password

# The phone number / SIP URI to call for warm transfer
HUMAN_AGENT_PHONE=+1XXXXXXXXXX

# ─── FastAPI Server ─────────────────────────────────────────
PORT=8000
